{
  "name": "merc-bot",
  "version": "2.0.0",
  "module": "index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "merc": "./index.tsx"
  },
  "scripts": {
    "lint": "bunx biome lint .",
    "lint:fix": "bunx biome lint --write .",
    "format": "bunx biome format .",
    "format:fix": "bunx biome format --write .",
    "check": "bunx biome check .",
    "check:fix": "bunx biome check --write .",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun build --compile index.tsx --outfile merc",
    "postinstall": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "latest",
    "lefthook": "^2.1.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/diff": "^8.0.0",
    "@types/react": "^19.2.14",
    "chalk": "4",
    "diff": "^8.0.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^17.0.4",
    "marked-terminal": "^7.3.0",
    "openai": "^6.25.0",
    "react": "^19.2.4",
    "react-devtools-core": "file:./stubs/react-devtools-core"
  }
}
